[Unit]
Description=Copilot Inbox Worker - processes Telegram messages via Copilot CLI
After=network-online.target copilot-telegram.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root
ExecStart=/usr/bin/python3 /opt/copilot-tools/inbox-worker.py
Restart=on-failure
RestartSec=10
StandardOutput=append:%h/.copilot-worker.log
StandardError=append:%h/.copilot-worker.log

[Install]
WantedBy=default.target
